{
  "$defs": {
    "FlowEvent": {
      "additionalProperties": false,
      "description": "A single observed network flow with traffic stats and any IOC matches.",
      "properties": {
        "app_proto": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Detected application protocol: HTTP / DNS / TLS / SSH / ...",
          "title": "App Proto"
        },
        "bytes_recv": {
          "minimum": 0,
          "title": "Bytes Recv",
          "type": "integer"
        },
        "bytes_sent": {
          "minimum": 0,
          "title": "Bytes Sent",
          "type": "integer"
        },
        "dns_query": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dns Query"
        },
        "dst_ip": {
          "format": "ipvanyaddress",
          "title": "Dst Ip",
          "type": "string"
        },
        "dst_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dst Port"
        },
        "end_ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "End Ts",
          "type": "string"
        },
        "flow_id": {
          "title": "Flow Id",
          "type": "string"
        },
        "host_id": {
          "description": "Identifies the vantage point that observed the flow (typically the collector host or interface)",
          "title": "Host Id",
          "type": "string"
        },
        "ja3": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "JA3 TLS client fingerprint",
          "title": "Ja3"
        },
        "packets_recv": {
          "default": 0,
          "minimum": 0,
          "title": "Packets Recv",
          "type": "integer"
        },
        "packets_sent": {
          "default": 0,
          "minimum": 0,
          "title": "Packets Sent",
          "type": "integer"
        },
        "proto": {
          "enum": [
            "tcp",
            "udp",
            "icmp",
            "other"
          ],
          "title": "Proto",
          "type": "string"
        },
        "src_ip": {
          "format": "ipvanyaddress",
          "title": "Src Ip",
          "type": "string"
        },
        "src_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Src Port"
        },
        "start_ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "Start Ts",
          "type": "string"
        },
        "threat_intel": {
          "description": "IOC matches found by collector-side preliminary processing",
          "items": {
            "$ref": "#/$defs/ThreatMatch"
          },
          "title": "Threat Intel",
          "type": "array"
        },
        "tls_sni": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tls Sni"
        }
      },
      "required": [
        "flow_id",
        "host_id",
        "start_ts",
        "end_ts",
        "proto",
        "src_ip",
        "dst_ip",
        "bytes_sent",
        "bytes_recv"
      ],
      "title": "FlowEvent",
      "type": "object"
    },
    "IndicatorType": {
      "description": "Type of indicator of compromise that was matched.",
      "enum": [
        "ip",
        "domain",
        "ja3"
      ],
      "title": "IndicatorType",
      "type": "string"
    },
    "Severity": {
      "description": "Severity level of a finding, ordered from informational to critical.",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "ThreatMatch": {
      "additionalProperties": false,
      "description": "One IOC hit observed on a flow.",
      "properties": {
        "category": {
          "description": "Threat category, e.g. 'c2', 'malware', 'phishing', 'tor-exit', 'scanner'",
          "title": "Category",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "indicator": {
          "description": "The matched IOC value (IP / domain / JA3 hash)",
          "title": "Indicator",
          "type": "string"
        },
        "indicator_type": {
          "$ref": "#/$defs/IndicatorType"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "source": {
          "description": "Name of the IOC feed that produced the match",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "indicator",
        "indicator_type",
        "category",
        "severity",
        "source"
      ],
      "title": "ThreatMatch",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "collector -> fusion: a batch of flow events from one collector instance.",
  "properties": {
    "batch_id": {
      "title": "Batch Id",
      "type": "string"
    },
    "collected_at": {
      "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
      "format": "date-time",
      "title": "Collected At",
      "type": "string"
    },
    "collector_id": {
      "title": "Collector Id",
      "type": "string"
    },
    "collector_version": {
      "title": "Collector Version",
      "type": "string"
    },
    "flows": {
      "items": {
        "$ref": "#/$defs/FlowEvent"
      },
      "title": "Flows",
      "type": "array"
    }
  },
  "required": [
    "batch_id",
    "collected_at",
    "collector_id",
    "collector_version"
  ],
  "title": "FlowBatch",
  "type": "object"
}
