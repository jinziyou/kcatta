{
  "$defs": {
    "AlertStatus": {
      "description": "Lifecycle state of an alert as it is triaged.",
      "enum": [
        "open",
        "acknowledged",
        "closed"
      ],
      "title": "AlertStatus",
      "type": "string"
    },
    "Severity": {
      "description": "Severity level of a finding, ordered from informational to critical.",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "description": "A correlated security alert linking related assets, vulnerabilities, and events.",
  "properties": {
    "alert_id": {
      "maxLength": 256,
      "title": "Alert Id",
      "type": "string"
    },
    "alert_key": {
      "anyOf": [
        {
          "maxLength": 256,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Alert Key"
    },
    "assignee": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Assignee"
    },
    "created_at": {
      "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "last_seen": {
      "anyOf": [
        {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Seen"
    },
    "note": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Note"
    },
    "occurrence_count": {
      "default": 1,
      "minimum": 1,
      "title": "Occurrence Count",
      "type": "integer"
    },
    "related_asset_ids": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "maxItems": 256,
      "title": "Related Asset Ids",
      "type": "array"
    },
    "related_trace_ids": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "maxItems": 256,
      "title": "Related Trace Ids",
      "type": "array"
    },
    "related_vuln_ids": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "maxItems": 256,
      "title": "Related Vuln Ids",
      "type": "array"
    },
    "score": {
      "description": "Risk score, 0-100",
      "maximum": 100.0,
      "minimum": 0.0,
      "title": "Score",
      "type": "number"
    },
    "severity": {
      "$ref": "#/$defs/Severity"
    },
    "status": {
      "$ref": "#/$defs/AlertStatus",
      "default": "open"
    },
    "suppressed": {
      "default": false,
      "title": "Suppressed",
      "type": "boolean"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "updated_at": {
      "anyOf": [
        {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    }
  },
  "required": [
    "alert_id",
    "severity",
    "score",
    "title",
    "description",
    "created_at"
  ],
  "title": "Alert",
  "type": "object"
}
