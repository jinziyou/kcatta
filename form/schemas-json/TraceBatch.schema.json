{
  "$defs": {
    "FileTraceEvent": {
      "description": "A single file-system operation observed by the eBPF tracer.\n\nCaptured from kernel tracepoints / LSM hooks (open, write, unlink, rename,\nchmod, ...) and attributed to the process that performed it.",
      "properties": {
        "comm": {
          "description": "Short process name (kernel TASK_COMM, <=16 bytes).",
          "maxLength": 256,
          "title": "Comm",
          "type": "string"
        },
        "host_id": {
          "description": "Vantage point that observed the operation.",
          "maxLength": 256,
          "title": "Host Id",
          "type": "string"
        },
        "op": {
          "enum": [
            "open",
            "create",
            "write",
            "unlink",
            "rename",
            "chmod",
            "link",
            "symlink",
            "mkdir"
          ],
          "title": "Op",
          "type": "string"
        },
        "path": {
          "description": "Primary target path of the operation.",
          "title": "Path",
          "type": "string"
        },
        "pid": {
          "description": "PID of the process performing the operation.",
          "minimum": 0,
          "title": "Pid",
          "type": "integer"
        },
        "ret": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Syscall return value (fd or -errno) when captured.",
          "title": "Ret"
        },
        "target_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Second path for link / rename operations.",
          "title": "Target Path"
        },
        "threat_intel": {
          "description": "IOC matches (known-bad path / hash) from collector-side processing.",
          "items": {
            "$ref": "#/$defs/ThreatMatch"
          },
          "maxItems": 64,
          "title": "Threat Intel",
          "type": "array"
        },
        "trace_id": {
          "maxLength": 256,
          "title": "Trace Id",
          "type": "string"
        },
        "ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "Ts",
          "type": "string"
        },
        "uid": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Acting user id when known.",
          "title": "Uid"
        }
      },
      "required": [
        "trace_id",
        "host_id",
        "ts",
        "pid",
        "comm",
        "op",
        "path"
      ],
      "title": "FileTraceEvent",
      "type": "object"
    },
    "IndicatorType": {
      "description": "Type of indicator of compromise that was matched.",
      "enum": [
        "ip",
        "domain",
        "ja3"
      ],
      "title": "IndicatorType",
      "type": "string"
    },
    "ProcessTraceEvent": {
      "description": "A process lifecycle event observed by the eBPF tracer.\n\nCaptured from sched_process_exec / sched_process_exit tracepoints: program\ninvocations (execve) and their exits, with parent and cgroup attribution.",
      "properties": {
        "argv": {
          "description": "Command-line arguments for exec events.",
          "items": {
            "type": "string"
          },
          "maxItems": 256,
          "title": "Argv",
          "type": "array"
        },
        "cgroup": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "cgroup / container id for workload attribution.",
          "title": "Cgroup"
        },
        "comm": {
          "description": "Short process name (kernel TASK_COMM, <=16 bytes).",
          "maxLength": 256,
          "title": "Comm",
          "type": "string"
        },
        "event_type": {
          "enum": [
            "exec",
            "exit"
          ],
          "title": "Event Type",
          "type": "string"
        },
        "exe": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Resolved executable path for exec events.",
          "title": "Exe"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Exit code for exit events.",
          "title": "Exit Code"
        },
        "host_id": {
          "description": "Vantage point that observed the event.",
          "maxLength": 256,
          "title": "Host Id",
          "type": "string"
        },
        "pid": {
          "minimum": 0,
          "title": "Pid",
          "type": "integer"
        },
        "ppid": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Parent PID when known.",
          "title": "Ppid"
        },
        "threat_intel": {
          "description": "IOC matches (known-bad binary hash / name) from collector-side processing.",
          "items": {
            "$ref": "#/$defs/ThreatMatch"
          },
          "maxItems": 64,
          "title": "Threat Intel",
          "type": "array"
        },
        "trace_id": {
          "maxLength": 256,
          "title": "Trace Id",
          "type": "string"
        },
        "ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "Ts",
          "type": "string"
        },
        "uid": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Acting user id when known.",
          "title": "Uid"
        }
      },
      "required": [
        "trace_id",
        "host_id",
        "ts",
        "event_type",
        "pid",
        "comm"
      ],
      "title": "ProcessTraceEvent",
      "type": "object"
    },
    "Severity": {
      "description": "Severity level of a finding, ordered from informational to critical.",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "ThreatMatch": {
      "description": "One IOC hit observed on a flow.",
      "properties": {
        "category": {
          "description": "Threat category, e.g. 'c2', 'malware', 'phishing', 'tor-exit', 'scanner'",
          "maxLength": 256,
          "title": "Category",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "indicator": {
          "description": "The matched IOC value (IP / domain / JA3 hash)",
          "maxLength": 256,
          "title": "Indicator",
          "type": "string"
        },
        "indicator_type": {
          "$ref": "#/$defs/IndicatorType"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "source": {
          "description": "Name of the IOC feed that produced the match",
          "maxLength": 256,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "indicator",
        "indicator_type",
        "category",
        "severity",
        "source"
      ],
      "title": "ThreatMatch",
      "type": "object"
    },
    "TraceEvent": {
      "description": "A single observed network trace with traffic stats and any IOC matches.",
      "properties": {
        "app_proto": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Detected application protocol: HTTP / DNS / TLS / SSH / ...",
          "title": "App Proto"
        },
        "bytes_recv": {
          "minimum": 0,
          "title": "Bytes Recv",
          "type": "integer"
        },
        "bytes_sent": {
          "minimum": 0,
          "title": "Bytes Sent",
          "type": "integer"
        },
        "dns_query": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dns Query"
        },
        "dst_ip": {
          "format": "ipvanyaddress",
          "title": "Dst Ip",
          "type": "string"
        },
        "dst_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dst Port"
        },
        "end_ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "End Ts",
          "type": "string"
        },
        "host_id": {
          "description": "Identifies the vantage point that observed the trace (typically the collector host or interface)",
          "maxLength": 256,
          "title": "Host Id",
          "type": "string"
        },
        "ja3": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "JA3 TLS client fingerprint",
          "title": "Ja3"
        },
        "packets_recv": {
          "default": 0,
          "minimum": 0,
          "title": "Packets Recv",
          "type": "integer"
        },
        "packets_sent": {
          "default": 0,
          "minimum": 0,
          "title": "Packets Sent",
          "type": "integer"
        },
        "proto": {
          "enum": [
            "tcp",
            "udp",
            "icmp",
            "other"
          ],
          "title": "Proto",
          "type": "string"
        },
        "src_ip": {
          "format": "ipvanyaddress",
          "title": "Src Ip",
          "type": "string"
        },
        "src_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Src Port"
        },
        "start_ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "Start Ts",
          "type": "string"
        },
        "threat_intel": {
          "description": "IOC matches found by collector-side preliminary processing",
          "items": {
            "$ref": "#/$defs/ThreatMatch"
          },
          "maxItems": 64,
          "title": "Threat Intel",
          "type": "array"
        },
        "tls_sni": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tls Sni"
        },
        "trace_id": {
          "maxLength": 256,
          "title": "Trace Id",
          "type": "string"
        }
      },
      "required": [
        "trace_id",
        "host_id",
        "start_ts",
        "end_ts",
        "proto",
        "src_ip",
        "dst_ip",
        "bytes_sent",
        "bytes_recv"
      ],
      "title": "TraceEvent",
      "type": "object"
    }
  },
  "description": "agentd -> Form -> analyzer: trace events from one collector instance.\n\nCarries three homogeneous streams from one eBPF collection cycle: network\ntraces (5-tuple flows), file operations, and process lifecycle events.",
  "properties": {
    "batch_id": {
      "maxLength": 256,
      "title": "Batch Id",
      "type": "string"
    },
    "collected_at": {
      "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
      "format": "date-time",
      "title": "Collected At",
      "type": "string"
    },
    "collector_id": {
      "maxLength": 256,
      "title": "Collector Id",
      "type": "string"
    },
    "collector_version": {
      "maxLength": 256,
      "title": "Collector Version",
      "type": "string"
    },
    "events": {
      "description": "Network traces (5-tuple flows + IOC matches).",
      "items": {
        "$ref": "#/$defs/TraceEvent"
      },
      "maxItems": 4096,
      "title": "Events",
      "type": "array"
    },
    "file_events": {
      "description": "File-system operations observed by the eBPF tracer.",
      "items": {
        "$ref": "#/$defs/FileTraceEvent"
      },
      "maxItems": 4096,
      "title": "File Events",
      "type": "array"
    },
    "process_events": {
      "description": "Process exec/exit events observed by the eBPF tracer.",
      "items": {
        "$ref": "#/$defs/ProcessTraceEvent"
      },
      "maxItems": 4096,
      "title": "Process Events",
      "type": "array"
    },
    "source_agent_id": {
      "anyOf": [
        {
          "maxLength": 256,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Authenticated Agent identity injected by Form; never trusted from payload",
      "title": "Source Agent Id"
    },
    "source_target_id": {
      "anyOf": [
        {
          "maxLength": 256,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Form-owned registered target attribution; absent only for unbound legacy telemetry",
      "title": "Source Target Id"
    }
  },
  "required": [
    "batch_id",
    "collected_at",
    "collector_id",
    "collector_version"
  ],
  "title": "TraceBatch",
  "type": "object"
}
