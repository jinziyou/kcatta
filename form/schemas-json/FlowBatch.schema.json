{
  "$defs": {
    "FlowEvent": {
      "additionalProperties": false,
      "properties": {
        "app_proto": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Detected application protocol: HTTP / DNS / TLS / SSH / ...",
          "title": "App Proto"
        },
        "bytes_recv": {
          "minimum": 0,
          "title": "Bytes Recv",
          "type": "integer"
        },
        "bytes_sent": {
          "minimum": 0,
          "title": "Bytes Sent",
          "type": "integer"
        },
        "dns_query": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dns Query"
        },
        "dst_ip": {
          "format": "ipvanyaddress",
          "title": "Dst Ip",
          "type": "string"
        },
        "dst_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dst Port"
        },
        "end_ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "End Ts",
          "type": "string"
        },
        "flow_id": {
          "title": "Flow Id",
          "type": "string"
        },
        "host_id": {
          "description": "Identifies the vantage point that observed the flow (typically the collector host or interface)",
          "title": "Host Id",
          "type": "string"
        },
        "ja3": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "JA3 TLS client fingerprint",
          "title": "Ja3"
        },
        "packets_recv": {
          "default": 0,
          "minimum": 0,
          "title": "Packets Recv",
          "type": "integer"
        },
        "packets_sent": {
          "default": 0,
          "minimum": 0,
          "title": "Packets Sent",
          "type": "integer"
        },
        "proto": {
          "enum": [
            "tcp",
            "udp",
            "icmp",
            "other"
          ],
          "title": "Proto",
          "type": "string"
        },
        "src_ip": {
          "format": "ipvanyaddress",
          "title": "Src Ip",
          "type": "string"
        },
        "src_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Src Port"
        },
        "start_ts": {
          "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
          "format": "date-time",
          "title": "Start Ts",
          "type": "string"
        },
        "tls_sni": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tls Sni"
        }
      },
      "required": [
        "flow_id",
        "host_id",
        "start_ts",
        "end_ts",
        "proto",
        "src_ip",
        "dst_ip",
        "bytes_sent",
        "bytes_recv"
      ],
      "title": "FlowEvent",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "collector -> form: a batch of flow events from one collector instance.",
  "properties": {
    "batch_id": {
      "title": "Batch Id",
      "type": "string"
    },
    "collected_at": {
      "description": "UTC timestamp encoded as RFC 3339 / ISO 8601",
      "format": "date-time",
      "title": "Collected At",
      "type": "string"
    },
    "collector_id": {
      "title": "Collector Id",
      "type": "string"
    },
    "collector_version": {
      "title": "Collector Version",
      "type": "string"
    },
    "flows": {
      "items": {
        "$ref": "#/$defs/FlowEvent"
      },
      "title": "Flows",
      "type": "array"
    }
  },
  "required": [
    "batch_id",
    "collected_at",
    "collector_id",
    "collector_version"
  ],
  "title": "FlowBatch",
  "type": "object"
}
