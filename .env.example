# Shared bearer token for form API auth (ingest + reports + detect).
# When unset in bare-metal dev, form accepts unauthenticated requests.
FORM_API_TOKEN=dev-token-change-me

# Persistence: jsonl (default) or sqlite (recommended for production / docker compose)
# FORM_STORAGE=sqlite

# Where form persists data (JSONL files / SQLite db). Default: data
# FORM_DATA_DIR=data

# Local OSV advisory store used by vulnerability detection. Default: data/osv
# FORM_OSV_DIR=data/osv

# Pin the OSV ecosystem instead of inferring from host.os (e.g. Debian:12).
# FORM_OSV_ECOSYSTEM=Debian:12

# CORS allow-list for the form API. Default: http://localhost:3000 (portal dev).
# FORM_CORS_ORIGINS=http://localhost:3000

# Base URL the portal uses to reach form. NEXT_PUBLIC_* is baked in at build
# time (Next.js), not read at runtime — in Docker pass it via --build-arg.
# Default: http://127.0.0.1:8000
# NEXT_PUBLIC_FORM_BASE_URL=http://127.0.0.1:8000
