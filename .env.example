# Shared bearer token for analyzer API auth (guards /ingest, /reports, /detect,
# /attack-paths, /targets, /scans; /health stays public). When unset in
# bare-metal dev, analyzer accepts unauthenticated requests. docker compose
# REQUIRES this to be set (it refuses to start with a built-in default) —
# pick a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ANALYZER_API_TOKEN=

# Persistence: jsonl (default) or sqlite (recommended for production / docker compose)
# ANALYZER_STORAGE=sqlite

# Where analyzer persists data (JSONL files / SQLite db). Default: data
# ANALYZER_DATA_DIR=data

# Local OSV advisory store used by vulnerability detection. Default: data/osv
# ANALYZER_OSV_DIR=data/osv

# Pin the OSV ecosystem instead of inferring from host.os (e.g. Debian:12).
# ANALYZER_OSV_ECOSYSTEM=Debian:12

# CORS allow-list for the analyzer API. Default: http://localhost:3000 (admin dev).
# ANALYZER_CORS_ORIGINS=http://localhost:3000

# Base URL the admin uses to reach analyzer. NEXT_PUBLIC_* is baked in at build
# time (Next.js), not read at runtime — in Docker pass it via --build-arg.
# Default: http://127.0.0.1:8000
# NEXT_PUBLIC_ANALYZER_BASE_URL=http://127.0.0.1:8000
