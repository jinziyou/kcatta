# Admin -> Form control/query token. Docker Compose generates one when unset.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# FORM_API_TOKEN=
# FORM_ALLOW_INSECURE_NO_AUTH=false

# Legacy Agent -> Form ingest-only token. It is retained only while
# FORM_AGENT_AUTH_MODE=mixed (or legacy) and never authorizes target, job,
# credential, report or triage APIs. Strict mtls mode does not require it.
# FORM_INGEST_TOKEN=

# Monitoring -> Form metrics-only token. Compose generates an isolated value;
# it authorizes only the read-only /metrics route and is never given to Admin.
# FORM_METRICS_TOKEN=

# Form -> Analyzer private service token. Never distribute this value to Admin
# or endpoints. Analyzer accepts no Admin/Agent credential directly.
# ANALYZER_INTERNAL_TOKEN=
# Monitoring -> Analyzer metrics-only token. Compose generates an isolated value
# that cannot authorize ingest, report, alert, detect, or readiness routes.
# ANALYZER_METRICS_TOKEN=
# ANALYZER_ALLOW_INSECURE_NO_AUTH=false

# Legacy bearer-ingest URL on the Form control listener (:10067). Keep this only
# while migrating already deployed Agents in mixed/legacy mode.
# FORM_PUBLIC_URL=https://form.example.com
# Dedicated Agent ingest URL. New resident Agents use this HTTPS endpoint and a
# per-Agent client certificate; the listener exposes only the three /ingest
# telemetry routes (plus health probes), normally on :10443.
# FORM_AGENT_PUBLIC_URL=https://agents.example.com:10443
# mixed: new Agents use mTLS while old bearer Agents can still use :10067.
# mtls: reject bearer ingest and do not require FORM_INGEST_TOKEN.
# legacy: compatibility only; do not provision new deployments this way.
# FORM_AGENT_AUTH_MODE=mixed
# FORM_AGENT_IDENTITY_ENABLED=true
# FORM_ALLOW_INSECURE_HTTP=false

# Per-Agent identity state and online CA material. FORM_AGENT_PKI_DIR contains
# the signing key and must be mounted only into the control Form process. The
# dedicated form-agent listener receives the identity registry and TLS/public
# CA material, never the signing key. Compose supplies its own internal paths.
# FORM_AGENT_IDENTITY_DATA_DIR=/var/lib/kcatta/form-agent-identities
# FORM_AGENT_PKI_DIR=/var/lib/kcatta/credentials/agent-pki
# FORM_AGENT_TLS_DIR=/var/lib/kcatta/form-agent-tls
# Server certificate name and optional comma-separated extra DNS/IP SANs.
# FORM_AGENT_TLS_SERVER_NAME=agents.example.com
# FORM_AGENT_TLS_SANS=form-agent,192.0.2.10
# Control renewal cadence (bounded to at most 24h), listener generation poll,
# and graceful Uvicorn recycle timeout.
# FORM_AGENT_TLS_RENEW_CHECK_SECONDS=21600
# FORM_AGENT_TLS_RELOAD_POLL_SECONDS=5
# FORM_AGENT_TLS_GRACEFUL_SHUTDOWN_SECONDS=30
# Bare-metal form-agent listener paths (Compose derives these from
# FORM_AGENT_TLS_DIR and mounts the directory read-only into the listener).
# FORM_AGENT_TLS_CERT=/var/lib/kcatta/form-agent-tls/current/server-cert.pem
# FORM_AGENT_TLS_KEY=/var/lib/kcatta/form-agent-tls/current/server-key.pem
# FORM_AGENT_TLS_CLIENT_CA=/var/lib/kcatta/form-agent-tls/ca-cert.pem

# Compose binds Admin, Form control, and the Agent listener to loopback by
# default. Expose :10443 directly or through L4 TCP/TLS pass-through so the
# listener receives the real client certificate; never expose Admin without
# an authentication proxy
# because the UI server holds the Form control token.
# FORM_BIND_ADDRESS=127.0.0.1
# FORM_AGENT_BIND_ADDRESS=127.0.0.1
# ADMIN_BIND_ADDRESS=127.0.0.1
# Optional `monitoring` profile UIs. Keep them on loopback unless protected by
# TLS/SSO/VPN. Prometheus stores 15 days by default.
# PROMETHEUS_BIND_ADDRESS=127.0.0.1
# MONITORING_DASHBOARD_BIND_ADDRESS=127.0.0.1
# PROMETHEUS_RETENTION_TIME=15d

# Form's private Analyzer URL. Compose sets this to http://analyzer:10068.
# FORM_ANALYZER_BASE_URL=http://127.0.0.1:10068

# Optional read-only Microsoft Defender for Endpoint cloud connector. Create an
# Entra application with Microsoft Graph application permissions
# SecurityAlert.Read.All and SecurityIncident.Read.All, grant tenant admin
# consent, then mount the secret as a file. There is deliberately no plaintext
# FORM_MDE_CLIENT_SECRET environment variable.
# FORM_MDE_ENABLED=false
# FORM_MDE_TENANT_ID=00000000-0000-0000-0000-000000000000
# FORM_MDE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# FORM_MDE_CLIENT_SECRET_FILE=/run/secrets/kcatta-mde-client-secret
# Optional JSON object: {"mde:<machine-id>":"<kcatta-host-id>", ...}
# FORM_MDE_HOST_MAP_FILE=/run/config/kcatta-mde-host-map.json
# FORM_MDE_STATE_PATH=data/mde-sync.db
# FORM_MDE_POLL_SECONDS=300
# FORM_MDE_INITIAL_LOOKBACK_HOURS=48
# FORM_MDE_OVERLAP_SECONDS=300
# FORM_MDE_MAX_PAGES=200
# FORM_MDE_MAX_ITEMS=20000

# Optional Microsoft Defender Vulnerability Management synchronization. Grant
# only the WindowsDefenderATP application permission Vulnerability.Read.All.
# Dedicated identity values take precedence; when omitted, the connector reuses
# FORM_MDE_TENANT_ID / CLIENT_ID / CLIENT_SECRET_FILE / HOST_MAP_FILE.
# FORM_MDVM_ENABLED=false
# FORM_MDVM_TENANT_ID=00000000-0000-0000-0000-000000000000
# FORM_MDVM_CLIENT_ID=00000000-0000-0000-0000-000000000000
# FORM_MDVM_CLIENT_SECRET_FILE=/run/secrets/kcatta-mdvm-client-secret
# FORM_MDVM_HOST_MAP_FILE=/run/config/kcatta-mde-host-map.json
# FORM_MDVM_STATE_PATH=data/mdvm-sync.db
# FORM_MDVM_API_HOST=api.security.microsoft.com
# FORM_MDVM_POLL_SECONDS=21600
# FORM_MDVM_BASELINE_REFRESH_HOURS=168
# FORM_MDVM_DELTA_OVERLAP_SECONDS=21600
# FORM_MDVM_PAGE_SIZE=1000
# FORM_MDVM_MAX_PAGES=200
# FORM_MDVM_MAX_ITEMS=50000
# FORM_MDVM_FINDINGS_PER_SNAPSHOT=512
# FORM_MDVM_SNAPSHOTS_PER_BATCH=32
# FORM_MDVM_BATCH_MAX_BYTES=3145728
# FORM_MDVM_STATE_MAX_FINDINGS=200000
# FORM_MDVM_STATE_MAX_BYTES=268435456

# Base URL used by the Admin server (not exposed to browser JavaScript).
# FORM_BASE_URL=http://127.0.0.1:10067
# Admin server request timeout; credential bootstrap may need longer than 8s.
# FORM_API_TIMEOUT_MS=30000

# Persistence: jsonl (default) or sqlite (recommended for production / docker compose)
# ANALYZER_STORAGE=sqlite
# FORM_STORAGE=sqlite

# Where analyzer persists data (JSONL files / SQLite db). Default: data
# ANALYZER_DATA_DIR=data
# FORM_DATA_DIR=data

# Analyzer durable-storage safety budgets. Compose defaults to a 1 GiB total
# SQLite budget, reserves 64 MiB for WAL, retains at most 96 MiB/100k rows per
# table, rejects a single record above 12 MiB, and bounds one tail read to 32 MiB.
# ANALYZER_SQLITE_MAX_BYTES=1073741824
# ANALYZER_SQLITE_WAL_MAX_BYTES=67108864
# ANALYZER_SQLITE_MAX_TABLE_BYTES=100663296
# ANALYZER_SQLITE_MAX_ROWS_PER_TABLE=100000
# ANALYZER_STORAGE_MAX_RECORD_BYTES=12582912
# ANALYZER_STORAGE_READ_MAX_BYTES=33554432
# Report-detail projection LRU (set either value to 0 to disable)
# ANALYZER_REPORT_PROJECTION_CACHE_ENTRIES=64
# ANALYZER_REPORT_PROJECTION_CACHE_BYTES=67108864
# JSONL deployments roll at a 256 MiB hard cap per file and fsync each ack.
# ANALYZER_JSONL_MAX_BYTES=268435456
# ANALYZER_JSONL_MAX_LINES=0
# ANALYZER_JSONL_FSYNC=true

# Local OSV advisory store used by vulnerability detection. Default: data/osv
# ANALYZER_OSV_DIR=data/osv
# Compose synchronizes the supported OSV ecosystems on an empty volume.
# ANALYZER_OSV_AUTO_SYNC=true

# Official Debian Security Tracker index used for conservative Kali coverage.
# Only exact dpkg source package/version matches are accepted; Kali forks are
# reported as unverified instead of inheriting Debian patch state.
# ANALYZER_DEBIAN_TRACKER_DIR=data/debian-tracker
# ANALYZER_DEBIAN_TRACKER_AUTO_SYNC=true
# Mark coverage stale after this many hours and retry an atomic refresh at the
# configured interval. A failed refresh keeps serving the previous index while
# readiness and detection coverage remain explicitly degraded.
# ANALYZER_DEBIAN_TRACKER_MAX_AGE_HOURS=48
# ANALYZER_DEBIAN_TRACKER_REFRESH_SECONDS=86400

# Pin the OSV ecosystem instead of inferring from host.os (e.g. Debian:12).
# ANALYZER_OSV_ECOSYSTEM=Debian:12

# Local Form scans include container/image assets by default. Disable this when
# a large Docker/containerd store makes host-root scans exceed the job timeout.
# FORM_LOCAL_SCAN_CONTAINER_ASSETS=true
# FORM_LOCAL_SCAN_PROJECT_DISCOVERY=true

# Directory of pre-built agent deploy binaries for form-scan/worker deployment.
# FORM_AGENT_TARGET_DIR=../agent/target
# Optional WinRM host collector override (e.g. an organization-signed MSVC PE).
# FORM_WINDOWS_AGENT_BINARY=/opt/kcatta/custom/agent-collect-host.exe

# Official trace binaries use real OS connection tables. Enable only after
# replacing agent-collect-trace with a custom build that includes `pcap`.
# FORM_TRACE_PCAP_ENABLED=false

# SSH host identity verification. accept-new (default) pins the first key in a
# persistent known_hosts file and rejects later changes; strict requires the key
# to be provisioned before the first connection.
# FORM_SSH_HOST_KEY_POLICY=accept-new
# FORM_SSH_KNOWN_HOSTS=/credentials/scdr/agent-remote/known_hosts

# WinRM HTTPS certificates are validated by default. Only a controlled lab with
# self-signed listeners should explicitly opt out.
# FORM_WINRM_SKIP_CERT_CHECK=false

# Max request body bytes accepted by ingest endpoints (oversized-upload guard).
# ANALYZER_MAX_BODY_BYTES=10485760

# Form enforces its own public request-size limit before proxying to Analyzer.
# FORM_MAX_BODY_BYTES=10485760
# Admission limits run before body buffering. Ingest buckets use the direct ASGI
# peer address and never trust X-Forwarded-For by themselves.
# FORM_MAX_IN_FLIGHT=16
# FORM_MAX_IN_FLIGHT_PER_PEER=8
# FORM_MAX_INGEST_IN_FLIGHT_PER_PEER=4
# FORM_INGEST_RATE_PER_SECOND=5
# FORM_INGEST_BURST=20
# FORM_BODY_READ_TIMEOUT_SECONDS=30
# Untrusted target artifact caps (one file / one scan execution total).
# A single trace artifact may contain several 9 MiB forwarding envelopes, so
# the default per-file budget matches the bounded per-scan aggregate budget.
# FORM_MAX_SCAN_ARTIFACT_BYTES=33554432
# FORM_MAX_SCAN_TOTAL_BYTES=33554432

# Bound in-process scan concurrency and total job time.
# FORM_MAX_CONCURRENT_SCANS=4
# FORM_SCAN_JOB_TIMEOUT_SECONDS=1800
# Fallback hard timeout inside SSH/WinRM commands. Job timeout/cancel actively
# interrupts local process groups and SSH channels earlier; WinRM also checks
# cancellation between its individually bounded WSMan operations.
# FORM_REMOTE_COMMAND_TIMEOUT_SECONDS=1800
# Durable queue lease/heartbeat/poll/retry settings. Heartbeat must be shorter
# than the lease; when unset its default is min(15, lease/3).
# FORM_SCAN_LEASE_SECONDS=60
# FORM_SCAN_HEARTBEAT_SECONDS=15
# FORM_SCAN_POLL_SECONDS=1
# FORM_SCAN_MAX_ATTEMPTS=3
# FORM_SCAN_RETRY_BASE_SECONDS=5
# FORM_SCAN_RETRY_MAX_SECONDS=300
# FORM_SCAN_SHUTDOWN_GRACE_SECONDS=15
# Dedicated scan-job SQLite budgets (jobs do not use FORM_STORAGE).
# FORM_SCAN_JOB_DB_MAX_BYTES=268435456
# FORM_SCAN_JOB_WAL_MAX_BYTES=16777216
# FORM_SCAN_JOB_MAX_RECORD_BYTES=65536
# FORM_SCAN_JOB_MAX_ROWS=100000
# FORM_SCAN_JOB_HISTORY_MAX_ROWS=100000
# Durable collect→Analyzer handoff spool budgets.
# FORM_SCAN_SPOOL_MAX_ARTIFACT_BYTES=37748736
# FORM_SCAN_SPOOL_MAX_TOTAL_BYTES=268435456
