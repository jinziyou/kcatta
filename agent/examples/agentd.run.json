{
  "upload_url": "http://127.0.0.1:10067",
  "interval_secs": 300,
  "host": {
    "enabled": true,
    "root": "/",
    "malware": true,
    "container_assets": true,
    "max_containers": 64,
    "include_stopped_containers": true,
    "container_images": true,
    "max_images": 32
  },
  "trace": {
    "enabled": true
  },
  "guard": {
    "enabled": false,
    "config_path": "/etc/kcatta/guard.json"
  }
}
