# Server-side base URL of the Form control-plane API.
# Defaults to http://127.0.0.1:10067 if unset. This is intentionally not a
# NEXT_PUBLIC_* variable: browsers never communicate with Form directly.
FORM_BASE_URL=http://127.0.0.1:10067

# Bearer token for server-side admin -> Form calls.
# Leave unset when Form runs without auth (local dev only).
# FORM_API_TOKEN=dev-token-change-me

# Optional request timeout in milliseconds. Default: 8000.
# FORM_API_TIMEOUT_MS=8000

# Optional HTTP Basic gate for the Admin UI (shared operator password).
# When both are set, browsers prompt for credentials. Leave unset for
# loopback-only / VPN-protected local development.
# ADMIN_BASIC_AUTH_USER=operator
# ADMIN_BASIC_AUTH_PASSWORD=change-me
