# Base URL of the fusion HTTP API.
# Defaults to http://127.0.0.1:8000 if unset.
# NOTE: NEXT_PUBLIC_* are baked in at build time (Next.js), not read at runtime —
# in Docker, pass via `--build-arg`, not the container environment.
NEXT_PUBLIC_FUSION_BASE_URL=http://127.0.0.1:8000

# Bearer token for server-side fusion API calls (matches fusion FUSION_API_TOKEN).
# Leave unset when fusion runs without auth (local dev default).
# FUSION_API_TOKEN=dev-token-change-me
