# Base URL of the form HTTP API.
# Defaults to http://127.0.0.1:8000 if unset.
# NOTE: NEXT_PUBLIC_* are baked in at build time (Next.js), not read at runtime —
# in Docker, pass via `--build-arg`, not the container environment.
NEXT_PUBLIC_FORM_BASE_URL=http://127.0.0.1:8000

# Bearer token for server-side form API calls (matches form FORM_API_TOKEN).
# Leave unset when form runs without auth (local dev default).
# FORM_API_TOKEN=dev-token-change-me
